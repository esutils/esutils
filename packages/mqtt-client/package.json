{
  "name": "@esutils/mqtt-client",
  "version": "0.1.2",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/esutils/esutils.git"
  },
  "description": "A minimal mqtt client library that implemented in `typescript`",
  "keywords": [
    "typescript",
    "mqtt",
    "client",
    "commonjs",
    "module",
    "es5",
    "es6",
    "es2015",
    "es2020",
    "es2022"
  ],
  "scripts": {
    "build": "yarn run -T tsc -p tsconfig.mjs.json",
    "prepublishOnly": "yarn run build",
    "test": "yarn run build && node --experimental-vm-modules ../../node_modules/jest/bin/jest.js --config jest.config.ts"
  },
  "type": "module",
  "types": "./dist/index.d.mts",
  "main": "./dist/index.mjs",
  "dependencies": {
    "@esutils/deferred": "0.1.2",
    "@esutils/mqtt-packet": "^0.0.2"
  }
}
