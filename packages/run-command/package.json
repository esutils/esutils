{
  "name": "@esutils/run-command",
  "version": "0.0.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/esutils/esutils.git"
  },
  "description": "Runs a shell command and returns a Promise that resolves with the stdout/stderr as buffers in `typescript`",
  "keywords": [
    "async",
    "asynchronous",
    "typescript",
    "run-command",
    "semaphore",
    "promise",
    "promises",
    "future",
    "futures",
    "continuation",
    "continuations",
    "commonjs",
    "module",
    "es5",
    "es6",
    "es2015",
    "es2020",
    "es2022"
  ],
  "scripts": {
    "build": "yarn run -T tsc -p tsconfig.mjs.json",
    "prepublishOnly": "yarn run build",
    "test": "yarn run build && node --experimental-vm-modules ../../node_modules/jest/bin/jest.js --config jest.config.ts"
  },
  "type": "module",
  "types": "./dist/index.d.mts",
  "main": "./dist/index.mjs"
}
