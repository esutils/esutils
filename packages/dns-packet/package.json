{
  "name": "@esutils/dns-packet",
  "version": "0.1.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/esutils/esutils.git"
  },
  "description": "A minimal dns-packet library that implemented in `typescript`",
  "keywords": [
    "typescript",
    "dns-packet",
    "commonjs",
    "module",
    "es5",
    "es6",
    "es2015",
    "es2020",
    "es2022"
  ],
  "scripts": {
    "build": "yarn run -T tsc -p tsconfig.mjs.json",
    "webpack": "yarn run -T webpack",
    "prepublishOnly": "yarn run build && yarn run -T webpack",
    "dns-proxy": "node --import=tsx examples/dns-proxy.ts",
    "dns-proxy-tsx": "yarn  run -T tsx examples/dns-proxy.ts",
    "test": "yarn run build && node --experimental-vm-modules ../../node_modules/jest/bin/jest.js --config jest.config.ts",
    "watch": "tsc -w -p tsconfig.mjs.json"
  },
  "type": "module",
  "types": "./dist/index.d.mts",
  "main": "./dist/index.mjs",
  "dependencies": {
    "@esutils/delay": "^0.1.1",
    "@esutils/invert": "^0.0.1"
  }
}
